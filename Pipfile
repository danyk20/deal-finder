[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

# Runtime dependencies come from pyproject.toml via an editable install of this package.
# "facebook" pulls in facebook-marketplace-scraper (its own dedicated browser + login flow).
# Every other marketplace adapter (tutti, Ricardo, AutoScout24) is a core dependency --
# each wraps a self-contained PyPI package that manages its own access internally.

[packages]
deal-finder = {extras = ["facebook"], path = ".", editable = true}

[dev-packages]
pytest = ">=8"
respx = ">=0.21"

[requires]
python_version = "3.13"

# Convenience: `pipenv run <name>`

[scripts]
dev = "uvicorn deal_finder.main:app --reload"
start = "uvicorn deal_finder.main:app --host 127.0.0.1 --port 8000"
test = "pytest -q"
fb-login = "python -m deal_finder.browser.fb_login"
telegram-chat-id = "python -m deal_finder.notify.telegram_setup"
