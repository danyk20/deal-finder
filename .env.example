# Copy to .env and edit. All keys are optional; sensible defaults apply.
# The app reads these at startup. A subset can also be edited live in the web UI (Settings),
# which is stored in the database and overrides these values.

# --- Database ---
# Leave this commented to use the stable default (~/.deal_finder/deal_finder.db), which
# keeps your watches + saved credentials regardless of where the app is launched from.
# Only set it to point elsewhere (use an ABSOLUTE path — a relative one moves with the CWD).
# DF_DATABASE_URL=sqlite:////Users/you/.deal_finder/deal_finder.db

# --- Email (SMTP) ---
# Example for Gmail: host=smtp.gmail.com port=587, user=you@gmail.com, password=<app password>
DF_SMTP_HOST=
DF_SMTP_PORT=587
DF_SMTP_USER=
DF_SMTP_PASSWORD=
DF_SMTP_FROM=
DF_SMTP_STARTTLS=true

# --- Local AI (Ollama, OpenAI-compatible endpoint) ---
# Install Ollama (brew install ollama), run `ollama serve`, then `ollama pull <model>`.
# Verify the exact available tag with `ollama list`. gemma4:12b is a good default on a Mac.
DF_AI_ENABLED=true
DF_OLLAMA_BASE_URL=http://localhost:11434/v1
DF_OLLAMA_MODEL=gemma4:12b
# Seconds to wait for a translation/Q&A response before giving up (email still sends,
# untranslated). Raise this if your machine is slow/CPU-only -- e.g. a 12B model at
# ~10 tok/s can take 2+ minutes for a long response. Also editable in Settings.
DF_OLLAMA_TIMEOUT=120

# --- Behaviour ---
DF_DEFAULT_NOTIFY_EMAIL=
DF_MAX_RESULTS_PER_RUN=50
# Seed mode: on a watch's first run, mark existing listings as seen WITHOUT emailing
# (prevents a flood of old listings). Only genuinely new listings are emailed afterwards.
DF_SEED_MODE=true
DF_HTTP_USER_AGENT=DealFinder/0.1 (personal monitoring; contact: change-me@example.com)
DF_REQUEST_TIMEOUT=20

# --- Browser automation (marketplace scanning drives a real Chrome like a human) ---
# First-time setup: pip install -e ".[browser]" && playwright install chrome
DF_BROWSER_HEADLESS=false                 # false = visible Chrome (best bot-detection bypass)
DF_BROWSER_CHANNEL=chrome                  # "chrome" uses your real Chrome; "" = bundled Chromium
DF_BROWSER_PROFILE_DIR=~/.deal_finder/profiles
DF_BROWSER_USER_AGENT=                     # blank = a realistic default Chrome UA
DF_BROWSER_MAX_ITEMS_PER_RUN=15            # listings opened one-at-a-time, per site, per run
DF_BROWSER_SEARCH_PAGES=2
DF_BROWSER_MIN_DELAY=2.5                   # random human delay between listings (seconds)
DF_BROWSER_MAX_DELAY=6.0
DF_BROWSER_NAV_TIMEOUT=45
DF_BROWSER_PROXY_URL=                      # optional CH residential proxy; blank = direct

# --- Which marketplaces to scan ---
# AutoScout24.ch uses a public JSON API directly (no browser, no anti-bot bypass needed).
DF_ADAPTER_TUTTI_USE_BROWSER=true
DF_ADAPTER_RICARDO_ENABLED=true
DF_ADAPTER_AUTOSCOUT24_ENABLED=false       # Akamai-protected; fragile — opt in
DF_ADAPTER_AUTOLINA_ENABLED=true           # plain HTML parsing, no browser needed
DF_ADAPTER_AUTOUNCLE_ENABLED=true          # schema.org JSON-LD + GraphQL, no browser needed
DF_ADAPTER_FACEBOOK_ENABLED=true           # ⚠ automating Facebook risks account bans

# --- Facebook (optional auto-login fallback) ---
# Preferred: log in once via `python -m deal_finder.browser.fb_login` (stores no password).
DF_FACEBOOK_EMAIL=
DF_FACEBOOK_PASSWORD=
